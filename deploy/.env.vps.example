# === Plantilla .env para VPS ===
# Copiar a la raíz del proyecto como .env y rellenar valores.
# En VPS: DATABASE_URL debe apuntar a PgBouncer (puerto 6432) o a postgres según tu compose.

# === PostgreSQL (Docker) ===
POSTGRES_USER=henry
POSTGRES_PASSWORD=GENERAR_PASSWORD_SEGURO
# Dentro de Docker: postgres://henry:PASSWORD@postgres:5432/assembly (o @pgbouncer:5432)
# Desde host (migraciones): postgres://henry:PASSWORD@localhost:5433/assembly
DATABASE_URL=postgres://henry:GENERAR_PASSWORD_SEGURO@postgres:5432/assembly

# === Auth (generar secretos aleatorios) ===
JWT_SECRET=GENERAR_64_CARACTERES
OTP_SECRET=GENERAR_32_CARACTERES
NEXTAUTH_SECRET=GENERAR_64_CARACTERES
NEXTAUTH_URL=https://tu-dominio.com

# === SMTP (OTPs) ===
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=TU_SENDGRID_API_KEY

# === Chatbots ===
TELEGRAM_BOT_TOKEN=TU_TOKEN_DE_BOTFATHER
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=TuBot_sin_arroba
GEMINI_API_KEY=TU_API_KEY_GOOGLE_AI_STUDIO
# Groq (opcional; si está configurado se usa antes que Gemini). console.groq.com
# GROQ_API_KEY=

# === Opcional: WhatsApp ===
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=

# === Producción ===
NODE_ENV=production
